{
  "name": "ra-fe-code-exercise-2026",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18",
    "npm": ">=10"
  },
  "scripts": {
    "server:setup": "node generate-members.js",
    "postinstall": "npm run server:setup",
    "dev-client": "vite",
    "dev-server": "json-server --watch --port 4002 --delay 1500 server.json",
    "dev": "conc \"npm:dev-*\"",
    "health-lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "health-test": "vitest run",
    "health-type": "tsc",
    "health": "conc \"npm:health-*\" --group",
    "test": "vitest watch"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.0.0",
    "json-server": "^0.17.4",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.2.2",
    "vite": "^6.4.1",
    "vite-plugin-svgr": "^4.2.0",
    "vitest": "^3.2.4"
  }
}
